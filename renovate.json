{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "minimumReleaseAge": "7 days",
  "packageRules": [
    {
      "matchManagers": [
        "npm"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "Major dependency updates"
    },
    {
      "matchManagers": [
        "npm"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "Minor and patch updates"
    },
    {
      "matchPackageNames": [
        "markdownlint",
        "markdownlint-rule-helpers"
      ],
      "groupName": "markdownlint updates",
      "reviewers": [
        "mensfeld"
      ]
    },
    {
      "matchPackageNames": [
        "eslint"
      ],
      "groupName": "ESLint updates"
    }
  ],
  "dependencyDashboard": true,
  "labels": [
    "dependencies"
  ],
  "reviewers": [
    "mensfeld"
  ],
  "assignees": [
    "mensfeld"
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "before 4am on the first day of the month"
    ]
  }
}
